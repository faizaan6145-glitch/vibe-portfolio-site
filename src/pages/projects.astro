---
import BaseLayout from "../layouts/BaseLayout.astro";
import NewsletterForm from "../components/NewsletterForm.astro";
import ProjectCard from "../components/ProjectCard.astro";

const projects = [
  {
    title: "Placeholder Project One",
    description: "Placeholder description for a featured project and its impact."
  },
  {
    title: "Placeholder Project Two",
    description: "Placeholder description highlighting goals, outcomes, and audience."
  },
  {
    title: "Placeholder Project Three",
    description: "Placeholder description for a current initiative or experiment."
  },
  {
    title: "Placeholder Project Four",
    description: "Placeholder description for a collaboration, product, or content series."
  }
];
---

<BaseLayout
  title="Faizaan | Projects"
  description="Placeholder projects page featuring Faizaan's current and past work."
  currentPath={Astro.url.pathname}
>
  <section class="space-y-6">
    <h1 class="text-5xl font-bold sm:text-6xl">Projects</h1>
    <p class="max-w-3xl text-lg">
      Placeholder content: a quick overview of Faizaan's selected projects, experiments, and ongoing work.
    </p>
  </section>

  <section class="mt-12 grid gap-5 sm:grid-cols-2">
    {projects.map((project) => <ProjectCard title={project.title} description={project.description} />)}
  </section>

  <section class="mt-16">
    <NewsletterForm
      title="Get New Project Updates"
      description="Placeholder copy: subscribe to hear when Faizaan launches new work."
    />
  </section>
</BaseLayout>
