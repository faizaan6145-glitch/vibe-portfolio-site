---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Join Faizaan's Weekly Newsletter",
  description = "Placeholder copy: get weekly insights, project updates, and behind-the-scenes notes."
} = Astro.props;
---

<section class="rounded border-2 border-black p-6 sm:p-8">
  <h2 class="text-3xl font-bold sm:text-4xl">{title}</h2>
  <p class="mt-3 max-w-2xl text-base">{description}</p>
  <form class="mt-6 flex flex-col gap-3 sm:flex-row" action="#" method="post">
    <label class="sr-only" for="email">Email address</label>
    <input
      id="email"
      name="email"
      type="email"
      required
      placeholder="placeholder@email.com"
      class="w-full border-2 border-black px-4 py-3 text-base placeholder:text-black/50"
    />
    <button
      type="submit"
      class="border-2 border-[#E10600] bg-[#E10600] px-6 py-3 text-base font-bold uppercase tracking-wide text-white transition-colors hover:bg-black hover:border-black"
    >
      Sign Up
    </button>
  </form>
</section>
